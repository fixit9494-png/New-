rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: services
    // Fields: name (string), description (string), duration (int), price (number)
    //
    // Collection: bookings
    // Fields: userId (string), userEmail (string), userName (string), serviceId (string), 
    //         serviceName (string), startTime (timestamp), endTime (timestamp), 
    //         status (string), createdAt (timestamp)
    //
    // Collection: users
    // Fields: uid (string), email (string), displayName (string), role (string)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (request.auth.token.email == "fixit9494@gmail.com" && request.auth.token.email_verified == true) ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        );
    }

    function isValidBooking(data) {
      return data.userId == request.auth.uid &&
             data.status in ['pending', 'confirmed', 'cancelled'] &&
             data.startTime is timestamp &&
             data.endTime is timestamp &&
             data.startTime < data.endTime;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && request.resource.data.role == 'client';
      allow update: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidBooking(request.resource.data);
      allow update: if isAuthenticated() && (
        (resource.data.userId == request.auth.uid && request.resource.data.status == 'cancelled' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }
  }
}
